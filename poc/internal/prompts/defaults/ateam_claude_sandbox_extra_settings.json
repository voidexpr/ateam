{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(*)",
      "Agent",
      "NotebookEdit",
      "AskUserQuestion",
      "Skill",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "LSP",
      "SendMessage",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "TeamCreate",
      "TeamDelete",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(ateam:init)",
      "Bash(ateam:install)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [
      "git:*",
      "go:*",
      "cargo:*",
      "npm:*", "npx:*",
      "bun:*", "bunx:*",
      "pnpm:*",
      "yarn:*",
      "pip:*", "pip3:*", "uv:*", "poetry:*",
      "gradle:*", "mvn:*",
      "docker:*",
      "ateam:*"
    ],
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "~/Library/Caches"
      ]
    },
    "network": {
      "allowedDomains": [
        "*.github.com",
        "*.githubusercontent.com",
        "registry.npmjs.org",
        "api.anthropic.com"
      ],
      "allowLocalBinding": true
    }
  }
}
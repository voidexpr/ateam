# Docker-in-Docker test environment for ateam docker container tests.
# Runs the Go integration tests inside an isolated Docker daemon
# so nothing touches the host system.
#
# Usage: make test-docker

FROM docker:27-dind

# Install build tools
RUN apk add --no-cache git musl-dev curl
ENV PATH="/usr/local/go/bin:${PATH}"

# Copy go.mod first, derive Go version, and install matching Go toolchain
WORKDIR /src
COPY go.mod .
RUN GO_VERSION=$(grep '^go ' go.mod | awk '{print $2}') && \
    echo "Installing Go ${GO_VERSION} (from go.mod)" && \
    curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" | tar -C /usr/local -xz

# Copy project source
COPY . .

# Pre-download Go modules while building the image
RUN go mod download

RUN chmod +x /src/test/run-docker-tests.sh

ENTRYPOINT ["/src/test/run-docker-tests.sh"]
